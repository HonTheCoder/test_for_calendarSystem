rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed()
        && exists(/databases/$(database)/documents/user_roles/$(request.auth.uid))
        && get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'Admin';
    }

    match /user_roles/{docId} {
      allow read:   if isAuthed();
      allow write:  if isAuthed() && request.auth.uid == docId;
    }

    match /admin_audit_logs/{doc} {
      allow read, write: if false;
    }

    match /users/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAdmin();
    }

    match /meetings/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /calendar_history/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if false;
      allow delete: if isAuthed();
    }

    match /announcements/{docId} {
      allow read:   if true;
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /notifications/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /notif_seen/{userId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if false;
    }

    match /dispatch_files/{docId} {
      function isDispatchOwner() {
        return resource != null && resource.data.uploadedBy == request.auth.uid;
      }
      function isRecipient() {
        return resource != null
          && resource.data.recipients is list
          && resource.data.recipients.hasAny([request.auth.uid]);
      }
      function isPublicDoc() {
        return resource != null && resource.data.type == 'public';
      }

      allow read: if isAuthed();

      allow create: if isAuthed()
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.type in ['public', 'private']
        && request.resource.data.fileName is string
        && request.resource.data.filePath is string
        && (
          request.resource.data.type == 'public'
          || (
            request.resource.data.recipients is list
            && request.resource.data.recipients.size() >= 1
            && request.resource.data.recipients.size() <= 5
          )
        );

      allow update: if false;

      allow delete: if isAuthed() && (isDispatchOwner() || isAdmin()
        || (resource.data.timestamp is timestamp
            && resource.data.timestamp < request.time - duration.value(7, 'd')));
    }

    match /settings/{docId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}