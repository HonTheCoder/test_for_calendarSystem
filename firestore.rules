rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return request.auth != null && request.auth.token.admin == true; }

    match /admin_audit_logs/{doc} {
      allow create: if isAdmin();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /users/{docId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && !('role' in request.resource.data.diff(resource.data).changedKeys()) && !('isAdmin' in request.resource.data.diff(resource.data).changedKeys()));
      allow delete: if isAdmin();
    }

    match /meetings/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /calendar_history/{docId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
