rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin audit logs: completely locked down ──────────────────────────────
    match /admin_audit_logs/{doc} {
      allow read, write: if false;
    }

    // ── Users collection ──────────────────────────────────────────────────────
    // Read: only authenticated users can read (needed for login lookup by username)
    // Create: only authenticated users (admins create accounts from the portal)
    // Update: authenticated users; role field is immutable via client (role changes
    //         must go through a Cloud Function or admin SDK)
    // Delete: only authenticated users
    match /users/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if request.auth != null;
    }

    // ── Meetings collection ───────────────────────────────────────────────────
    // All operations require authentication
    match /meetings/{docId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Calendar history: append-only, no deletion/updates from client ────────
    match /calendar_history/{docId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if false;
    }

    // ── Announcements ─────────────────────────────────────────────────────────
    // Read is public (users see announcements even before login screen loads)
    // Write requires authentication
    match /announcements/{docId} {
      allow read:           if true;
      allow create:         if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}