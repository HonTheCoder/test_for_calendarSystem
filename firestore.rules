rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /admin_audit_logs/{doc} {
      allow read, write: if false;
    }

    match /users/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /meetings/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /calendar_history/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if false;
      allow delete: if isAuthed();
    }

    match /announcements/{docId} {
      allow read:   if true;
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /notifications/{docId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /notif_seen/{userId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if false;
    }

    match /dispatch_files/{docId} {
      function isDispatchReader() {
        return isAdmin()
          || resource.data.type == 'public'
          || resource.data.uploadedBy == request.auth.uid
          || (resource.data.type == 'private'
              && 'recipients' in resource.data
              && request.auth.uid in resource.data.recipients);
      }
      function isDispatchOwner() {
        return resource.data.uploadedBy == request.auth.uid;
      }
      function isExpiredDispatch() {
        return resource.data.timestamp != null
          && resource.data.timestamp < request.time - duration.value(7, 'd');
      }
      allow read:   if isAuthed() && isDispatchReader();
      allow create: if isAuthed()
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.type in ['public', 'private']
        && request.resource.data.fileName is string
        && request.resource.data.filePath is string
        && (
          request.resource.data.type == 'public'
          || (
            request.resource.data.recipients is list
            && request.resource.data.recipients.size() >= 1
            && request.resource.data.recipients.size() <= 5
          )
        );
      allow update: if false;
      allow delete: if isAuthed() && (isAdmin() || isDispatchOwner() || isExpiredDispatch());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}