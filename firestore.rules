rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin audit logs: completely locked down ──────────────────────────────
    match /admin_audit_logs/{doc} {
      allow read, write: if false;
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.role != "Admin";
      allow update: if request.auth != null
                    && !('role' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if request.auth != null;
    }

    // ── Meetings collection ───────────────────────────────────────────────────
    match /meetings/{docId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Calendar history: append-only, no deletion/updates from client ────────
    match /calendar_history/{docId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if false;
    }

    // ── Announcements ─────────────────────────────────────────────────────────
    match /announcements/{docId} {
      allow read:           if true;
      allow create:         if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Fixed: was missing entirely — fell through to catch-all deny rule,
    // silently blocking all notification reads/writes in production.
    match /notifications/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}